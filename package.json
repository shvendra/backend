{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "NODE_ENV=production node server.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:monitor": "pm2 monit",
    "docker:build": "docker build -t bookmyworkers-backend .",
    "docker:run": "docker run -p 8000:8000 --env-file .env.production bookmyworkers-backend",
    "test:api": "node test-api-performance.js",
    "logs:clear": "rm -rf logs/* && mkdir -p logs",
    "cache:clear": "curl -X POST http://localhost:8000/api/v1/monitoring/cache/clear",
    "health:check": "curl http://localhost:8000/api/v1/monitoring/health"
  },
  "type": "module",
  "dependencies": {
    "aws-sdk": "^2.1693.0",
    "axios": "^1.8.4",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "canvas": "^3.1.0",
    "cloudinary": "^1.41.2",
    "compression": "^1.8.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.3",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "history": "^5.3.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongo-sanitize": "^1.1.0",
    "mongodb": "^6.17.0",
    "mongoose": "^8.15.1",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^6.10.1",
    "pg-sdk-node": "^2.0.2",
    "puppeteer": "^24.13.0",
    "rate-limiter-flexible": "^7.3.1",
    "redis": "^4.7.0",
    "sha256": "^0.2.0",
    "socket.io": "^4.8.1",
    "uniqid": "^5.4.0",
    "validator": "^13.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
